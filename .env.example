DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/postgres
JWT_SECRET=cambiar-por-secreto-largo-aleatorio
SYNC_API_KEY=clave-compartida-solo-agentes-y-servidor
ALLOWED_ORIGINS=https://tu-app.vercel.app,http://localhost:5173

